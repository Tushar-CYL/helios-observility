{
  "uid": "helios-agent-runs",
  "title": "HELIOS · Agent Runs Overview",
  "description": "Fleet-level view of agent executions: volume, errors, wrong answers, latency, tokens and cost.",
  "tags": ["helios", "agent-runtime-intelligence"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "framework",
        "label": "Framework",
        "type": "query",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
        "query": "SELECT DISTINCT agent_framework FROM helios.agent_run",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Runs",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT count() AS value FROM helios.agent_run WHERE agent_framework IN (${framework:singlequote})"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/.*/" }, "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errored Runs",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT countIf(status = 'error') AS value FROM helios.agent_run WHERE agent_framework IN (${framework:singlequote})"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/.*/" }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Wrong Answers",
      "description": "Runs whose final answer was evaluated incorrect (outcome_correct = false).",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT countIf(outcome_correct = 0) AS value FROM helios.agent_run WHERE agent_framework IN (${framework:singlequote})"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/.*/" }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] } }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Duration",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT round(avg(duration_ms)) AS value FROM helios.agent_run WHERE agent_framework IN (${framework:singlequote})"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/.*/" }, "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" }, "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Tokens",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT sum(input_tokens + output_tokens) AS value FROM helios.agent_run WHERE agent_framework IN (${framework:singlequote})"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/.*/" }, "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Cost",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT round(sum(cost_usd), 4) AS value FROM helios.agent_run WHERE agent_framework IN (${framework:singlequote})"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/.*/" }, "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "currencyUSD" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Recent Agent Runs",
      "gridPos": { "h": 11, "w": 18, "x": 0, "y": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT start_time AS \"Started\", agent_name AS \"Agent\", agent_framework AS \"Framework\", status AS \"Status\", duration_ms AS \"Duration (ms)\", (input_tokens + output_tokens) AS \"Tokens\", cost_usd AS \"Cost (USD)\", if(outcome_correct = 1, 'correct', if(outcome_correct = 0, 'WRONG', 'n/a')) AS \"Outcome\", input AS \"Task\" FROM helios.agent_run WHERE agent_framework IN (${framework:singlequote}) ORDER BY start_time DESC LIMIT 100"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-text" } }, { "id": "mappings", "value": [ { "type": "value", "options": { "error": { "color": "red", "index": 0 }, "ok": { "color": "green", "index": 1 } } } ] } ]
          },
          {
            "matcher": { "id": "byName", "options": "Outcome" },
            "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-text" } }, { "id": "mappings", "value": [ { "type": "value", "options": { "WRONG": { "color": "red", "index": 0 }, "correct": { "color": "green", "index": 1 } } } ] } ]
          },
          { "matcher": { "id": "byName", "options": "Cost (USD)" }, "properties": [ { "id": "unit", "value": "currencyUSD" } ] }
        ]
      }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Runs by Framework",
      "gridPos": { "h": 11, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "helios-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT agent_framework AS framework, count() AS runs FROM helios.agent_run GROUP BY agent_framework ORDER BY runs DESC"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^runs$/" }, "pieType": "donut", "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
