{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helios.dev/schema/v1/agent_run.schema.json",
  "title": "HELIOS agent_run (v1)",
  "description": "One logical agent execution. Maps to the root span of the run.",
  "type": "object",
  "unevaluatedProperties": false,
  "allOf": [{ "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/envelope" }],
  "properties": {
    "schema_version": { "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/semver" },
    "tenant_id": { "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/tenant_id" },
    "agent_run_id": { "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/uuid" },

    "trace_id": { "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/trace_id" },
    "root_span_id": { "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/span_id" },

    "agent_name": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string" },
    "agent_version": { "type": "string" },
    "agent_framework": {
      "type": "string",
      "enum": ["langgraph", "autogen", "crewai", "custom"]
    },

    "input": { "type": "string" },
    "output": { "type": "string" },

    "status": { "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/status" },

    "start_time": { "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/rfc3339" },
    "end_time": { "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/rfc3339" },
    "duration_ms": { "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/non_negative_int" },

    "input_tokens": { "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/non_negative_int" },
    "output_tokens": { "$ref": "https://helios.dev/schema/v1/common.schema.json#/$defs/non_negative_int" },
    "cost_usd": { "type": "number", "minimum": 0 },

    "outcome_correct": { "type": "boolean" }
  },
  "required": [
    "trace_id",
    "root_span_id",
    "agent_name",
    "status",
    "start_time",
    "end_time",
    "duration_ms"
  ]
}
